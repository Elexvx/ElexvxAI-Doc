---
import { SITE, type Lang } from "../config/site";
import { t } from "../i18n/ui";
import { getDocUrl } from "../lib/docs";
import { getBlogUrl } from "../lib/blog";

type Props = {
  lang: Lang;
  version?: string;
  slug?: string;
  kind?: "docs" | "blog" | "search";
};

const { lang, version, slug, kind = "docs" } = Astro.props;
const otherLang = lang === "zh" ? "en" : "zh";

const docsVersion = version ?? SITE.defaultVersion;

const currentHref =
  kind === "blog"
    ? getBlogUrl({ lang, slug })
    : kind === "search"
      ? `/${lang}/search/`
      : getDocUrl({ lang, version: docsVersion, slug });

const otherLangHref =
  kind === "blog"
    ? getBlogUrl({ lang: otherLang, slug })
    : kind === "search"
      ? `/${otherLang}/search/`
      : getDocUrl({ lang: otherLang, version: docsVersion, slug });

const brandHref =
  kind === "blog"
    ? getBlogUrl({ lang })
    : kind === "search"
      ? getDocUrl({ lang, version: docsVersion })
      : getDocUrl({ lang, version: docsVersion });
---

<header class="hdr" transition:persist="header">
  <div class="inner">
    <!-- Logo -->
    <a class="logo" href={brandHref}>
      <img src="/logo/favicon.svg" alt="ElexvxAI Logo" class="logo-img" />
    </a>

    <!-- Links -->
    <nav class="nav">
      <div class="nav-item">
        <a class="nav-link" href="/">{t(lang, "home")}</a>
      </div>
      <div class="nav-item">
        <a class="nav-link" href="#">{t(lang, "services")}</a>
      </div>
      <div class="nav-item">
        <a class="nav-link" href={getBlogUrl({ lang })}>{t(lang, "articles")}</a>
      </div>
      <div class="nav-item">
        <a class="nav-link" href="#">{t(lang, "company")}</a>
      </div>
    </nav>

    <!-- Controls -->
    <div class="controls">
      <button class="icon-btn" type="button" id="themeToggle" aria-label={t(lang, "theme")}>
        <svg class="sun" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
        <svg class="moon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>

      <a class="icon-btn" href="/rss.xml" aria-label="RSS">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"></path><path d="M4 4a16 16 0 0 1 16 16"></path><circle cx="5" cy="19" r="1"></circle></svg>
      </a>

      <button class="icon-btn menu-btn" id="menuToggle" aria-label="Toggle menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" x2="20" y1="12" y2="12"/>
          <line x1="4" x2="20" y1="6" y2="6"/>
          <line x1="4" x2="20" y1="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  import { t } from "../i18n/ui";

  // The Header is persisted across view transitions, so we need to run initialization logic on every page load
  // to ensure state (like current language/version) correctly reflects the URL.
  document.addEventListener("astro:page-load", () => {
    // Theme toggle Logic
    const btn = document.getElementById("themeToggle");
    if (btn && !btn.hasAttribute("data-theme-listener")) {
      btn.setAttribute("data-theme-listener", "true");
      // Initial state is handled by CSS (sun/moon visibility) or inline script in Head if present
      // But we can ensure correct aria-label
      btn.addEventListener("click", () => {
        const key = "theme";
        const cur = document.documentElement.dataset.theme || "dark";
        const next = cur === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = next;
        localStorage.setItem(key, next);
      });
    }
  });
</script>

<style>
  .hdr {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--header-h);
    background: color-mix(in srgb, var(--bg), transparent 20%);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(12px);
  }

  .inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    padding: 0 1rem;
    margin: 0 auto;
    max-width: 100%;
  }

  @media (min-width: 900px) {
    .inner {
      padding: 0 2rem;
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
      gap: 1.5rem;
    }
  }

  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    justify-self: start;
  }

  .logo-img {
    height: 32px;
    width: auto;
  }

  .nav {
    display: none;
  }

  @media (min-width: 900px) {
    .nav {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 2rem;
    }
  }

  .nav-link {
    display: flex;
    align-items: center;
    font-size: 0.875rem;
    padding: 0.375rem 0.75rem;
    border-radius: 0.375rem;
    color: var(--muted);
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s;
  }

  .nav-link:hover {
    color: var(--fg);
    background-color: var(--panel);
  }

  .controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    justify-self: end;
  }

  .icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.375rem;
    color: var(--muted);
    background: transparent;
    border: none;
    cursor: pointer;
    transition: all 0.2s;
    padding: 0;
  }

  .icon-btn:hover {
    color: var(--fg);
    background-color: var(--panel);
  }

  .menu-btn {
    display: flex;
  }

  @media (min-width: 900px) {
    .menu-btn {
      display: none;
    }
  }

  /* Theme toggle icons */
  :global([data-theme="dark"]) .sun { display: none; }
  :global([data-theme="light"]) .moon { display: none; }
</style>
