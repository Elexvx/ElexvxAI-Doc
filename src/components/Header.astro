---
import { SITE, type Lang } from "../config/site";
import { t } from "../i18n/ui";
import { getDocUrl } from "../lib/docs";
import { getBlogUrl } from "../lib/blog";

type Props = {
  lang: Lang;
  version?: string;
  slug?: string;
  kind?: "docs" | "blog" | "search";
};

const { lang, version, slug, kind = "docs" } = Astro.props;
const otherLang = lang === "zh" ? "en" : "zh";

const docsVersion = version ?? SITE.defaultVersion;

const currentHref =
  kind === "blog"
    ? getBlogUrl({ lang, slug })
    : kind === "search"
      ? `/${lang}/search/`
      : getDocUrl({ lang, version: docsVersion, slug });

const otherLangHref =
  kind === "blog"
    ? getBlogUrl({ lang: otherLang, slug })
    : kind === "search"
      ? `/${otherLang}/search/`
      : getDocUrl({ lang: otherLang, version: docsVersion, slug });

const brandHref =
  kind === "blog"
    ? getBlogUrl({ lang })
    : kind === "search"
      ? getDocUrl({ lang, version: docsVersion })
      : getDocUrl({ lang, version: docsVersion });
---

<header class="hdr" transition:persist="header">
  <div class="inner">
    <!-- Logo -->
    <a class="logo" href={brandHref}>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="logo-icon">
        <path d="M19.8 18.4L14 10.67V6.5l1.35-1.69c.26-.33.03-.81-.4-.81H9.05c-.43 0-.66.48-.4.81L10 6.5v4.17L4.2 18.4c-.49.66-.02 1.6.8 1.6h14c.82 0 1.29-.94.8-1.6z"></path>
      </svg>
      <span>ElexvxAI</span>
    </a>

    <!-- Links -->
    <nav class="nav">
      <div class="nav-item">
        <a class="nav-link" href={getDocUrl({ lang, version: docsVersion })}>{t(lang, "docs")}</a>
      </div>
      <div class="nav-item">
        <a class="nav-link" href={getBlogUrl({ lang })}>{t(lang, "blog")}</a>
      </div>
      <div class="nav-item">
        <a class="nav-link" href={`/${lang}/search/`}>{t(lang, "search")}</a>
      </div>
    </nav>

    <!-- Controls -->
    <div class="controls">
      {
        kind === "docs" ? (
          <div class="select-wrapper">
            <select id="versionSelect" aria-label={t(lang, "version")}>
              {SITE.versions.map((v) => (
                <option value={v} selected={v === docsVersion}>
                  {v}
                </option>
              ))}
            </select>
            <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
          </div>
        ) : null
      }
      <div class="select-wrapper">
        <select id="langSelect" aria-label={t(lang, "language")}>
          <option value={lang} selected>
            {lang.toUpperCase()}
          </option>
          <option value={otherLang}>{otherLang.toUpperCase()}</option>
        </select>
        <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
      </div>
      
      <button class="icon-btn" type="button" id="themeToggle" aria-label={t(lang, "theme")}>
        <svg class="sun" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
        <svg class="moon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>

      <button class="icon-btn menu-btn" id="menuToggle" aria-label="Toggle menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" x2="20" y1="12" y2="12"/>
          <line x1="4" x2="20" y1="6" y2="6"/>
          <line x1="4" x2="20" y1="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  import { navigate } from "astro:transitions/client";
  import { t } from "../i18n/ui";
  import type { Lang } from "../config/site";

  // The Header is persisted across view transitions, so we need to run initialization logic on every page load
  // to ensure state (like current language/version) correctly reflects the URL.
  document.addEventListener("astro:page-load", () => {
    const currentPathname = window.location.pathname;
    const matchLang = currentPathname.match(/^\/(en|zh)/);
    const currentLang = (matchLang ? matchLang[1] : document.documentElement.lang || "en") as Lang;

    // Theme toggle Logic
    const btn = document.getElementById("themeToggle");
    if (btn && !btn.hasAttribute("data-theme-listener")) {
      btn.setAttribute("data-theme-listener", "true");
      // Initial state is handled by CSS (sun/moon visibility) or inline script in Head if present
      // But we can ensure correct aria-label
      btn.addEventListener("click", () => {
        const key = "theme";
        const cur = document.documentElement.dataset.theme || "dark";
        const next = cur === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = next;
        localStorage.setItem(key, next);
      });
    }

    // Update active state in dom for language selector based on current URL path
    const langSelect = document.getElementById(
      "langSelect",
    ) as HTMLSelectElement;
    if (langSelect) {
      if (langSelect.value !== currentLang) {
        langSelect.value = currentLang;
      }

      if (!langSelect.hasAttribute("data-nav-listener")) {
        langSelect.setAttribute("data-nav-listener", "true");
        langSelect.addEventListener("change", (e) => {
          const targetLang = (e.target as HTMLSelectElement).value;
          // Only replace the leading language segment
          const newPathname = currentPathname.replace(
            /^\/(en|zh)/,
            `/${targetLang}`,
          );
          navigate(newPathname);
        });
      }
    }

    // Update active state in dom for version selector based on current URL path
    const versionSelect = document.getElementById(
      "versionSelect",
    ) as HTMLSelectElement;
    if (versionSelect) {
      // Find the version in the URL. Assuming structure like /en/docs/v2/...
      const versionMatch = currentPathname.match(/^\/[a-z]{2}\/docs\/(v\d+)/);
      if (versionMatch) {
        const currentVersion = versionMatch[1];
        if (versionSelect.value !== currentVersion) {
          versionSelect.value = currentVersion;
        }
      }

      if (!versionSelect.hasAttribute("data-nav-listener")) {
        versionSelect.setAttribute("data-nav-listener", "true");
        versionSelect.addEventListener("change", (e) => {
          const targetVersion = (e.target as HTMLSelectElement).value;
          // Identify where the version is right now and swap it out
          // Works for /en/docs/v2/...  or /zh/docs/v2/...
          const newPathname = currentPathname.replace(
            /(\/[a-z]{2}\/docs\/)v\d+/,
            `$1${targetVersion}`,
          );
          navigate(newPathname);
        });
      }
    }
  });
</script>

<style>
  .hdr {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--header-h);
    background: color-mix(in srgb, var(--bg), transparent 20%);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(12px);
  }

  .inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    padding: 0 1rem;
    margin: 0 auto;
    max-width: 100%;
  }

  @media (min-width: 768px) {
    .inner {
      padding: 0 2rem;
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
      gap: 1.5rem;
    }
  }

  .logo {
    display: flex;
    align-items: center;
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--fg);
    text-decoration: none;
    justify-self: start;
    white-space: nowrap;
    gap: 0.5rem;
  }

  .nav {
    display: none;
  }

  @media (min-width: 768px) {
    .nav {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.25rem;
    }
  }

  .nav-link {
    display: flex;
    align-items: center;
    font-size: 0.875rem;
    padding: 0.375rem 0.75rem;
    border-radius: 0.375rem;
    color: var(--muted);
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s;
  }

  .nav-link:hover {
    color: var(--fg);
    background-color: var(--panel);
  }

  .controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    justify-self: end;
  }

  .select-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  select {
    appearance: none;
    background: transparent;
    border: none;
    color: var(--muted);
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.375rem 1.75rem 0.375rem 0.5rem;
    cursor: pointer;
    border-radius: 0.375rem;
    transition: all 0.2s;
  }

  select:hover {
    color: var(--fg);
    background-color: var(--panel);
  }

  .chevron {
    position: absolute;
    right: 0.5rem;
    width: 1rem;
    height: 1rem;
    pointer-events: none;
    color: var(--muted);
  }

  .icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.375rem;
    color: var(--muted);
    background: transparent;
    border: none;
    cursor: pointer;
    transition: all 0.2s;
    padding: 0;
  }

  .icon-btn:hover {
    color: var(--fg);
    background-color: var(--panel);
  }

  .menu-btn {
    display: flex;
  }

  @media (min-width: 768px) {
    .menu-btn {
      display: none;
    }
  }

  /* Theme toggle icons */
  :global([data-theme="dark"]) .sun { display: none; }
  :global([data-theme="light"]) .moon { display: none; }
</style>
