---
import { type SidebarGroup, getDocUrl } from "../lib/docs";
import SearchBox from "./SearchBox.astro";
import { SITE, type Lang } from "../config/site";
import { t } from "../i18n/ui";
import { getBlogUrl } from "../lib/blog";
import {
  Home,
  Download,
  Settings,
  Tag,
  Database,
  Share2,
  FileText,
  X,
} from "@lucide/astro";

type Props = {
  groups: SidebarGroup[];
  currentPath: string;
  lang: Lang;
};

const { groups, currentPath, lang } = Astro.props;

const IconMap = {
  intro: Home,
  install: Download,
  config: Settings,
  api: Tag,
  sdk: Tag,
  data: Database,
  model: Share2,
  neural: Share2,
  default: FileText,
};

function getIconKey(title: string): keyof typeof IconMap {
  const t = title.toLowerCase();
  if (t.includes("intro")) return "intro";
  if (t.includes("install")) return "install";
  if (t.includes("config")) return "config";
  if (t.includes("api") || t.includes("sdk")) return "api";
  if (t.includes("data")) return "data";
  if (t.includes("model") || t.includes("neural")) return "model";
  return "default";
}
---

<div class="doc-drawer-overlay" id="sidebarOverlay"></div>
<aside class="doc-sidebar" id="sidebar" transition:persist="sidebar">
  <div class="doc-drawer-header">
    <span class="mobileTitle">Menu</span>
    <button class="closeBtn" id="sidebarClose" aria-label="Close menu">
      <X size={20} stroke-width={1.5} />
    </button>
  </div>

  <nav class="mobile-nav">
    <a class="mobile-nav-item" href="/">{t(lang, "home")}</a>
    <a
      class="mobile-nav-item"
      href={getDocUrl({ lang, version: SITE.defaultVersion })}
      >{t(lang, "docs")}</a
    >
    <a class="mobile-nav-item" href={getBlogUrl({ lang })}>{t(lang, "blog")}</a>
  </nav>

  <SearchBox lang={lang} />
  {
    groups.map((g) => (
      <details
        class="group"
        open={g.items.some(
          (it) => it.href === currentPath || it.href === `${currentPath}/`,
        )}
      >
        <summary class="groupTitle">{g.title}</summary>
        <ul class="list">
          {g.items.map((it) => {
            const active =
              it.href === currentPath || it.href === `${currentPath}/`;
            const IconComponent = IconMap[getIconKey(it.title)];
            return (
              <li>
                <a class:list={["item", active && "active"]} href={it.href}>
                  <span class="icon">
                    <IconComponent
                      class="sidebar-icon"
                      size={16}
                      stroke-width={1.5}
                    />
                  </span>
                  <span class="text">{it.title}</span>
                </a>
              </li>
            );
          })}
        </ul>
      </details>
    ))
  }
</aside>

<style>
  .mobile-nav {
    display: none;
  }

  @media (max-width: 1024px) {
    .mobile-nav {
      display: flex;
      flex-direction: column;
      padding: 0.5rem 0.5rem 1rem;
      gap: 0.25rem;
      border-bottom: 1px solid var(--border-2);
      margin-bottom: 0.5rem;
    }

    .mobile-nav-item {
      color: var(--muted);
      text-decoration: none;
      font-weight: 500;
      padding: 0.5rem 0.75rem;
      border-radius: 0.5rem;
      font-size: 0.95rem;
      transition: all 0.2s;
    }

    .mobile-nav-item:hover {
      color: var(--fg);
      background: var(--panel-2);
    }
  }

  .mobileTitle {
    font-weight: 600;
    font-size: 1rem;
  }

  .closeBtn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: none;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    border-radius: 0.5rem;
  }

  .closeBtn:hover {
    color: var(--fg);
    background: var(--panel-2);
  }

  .group {
    margin: 0.25rem 0 0.75rem;
    border-radius: var(--radius-md);
  }

  .groupTitle {
    list-style: none;
    font-size: 0.75rem;
    font-weight: 650;
    color: var(--muted-2);
    padding: 0.45rem 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    cursor: pointer;
    user-select: none;
  }

  details > summary::-webkit-details-marker {
    display: none;
  }

  details > summary::after {
    content: "";
    float: right;
    width: 10px;
    height: 10px;
    margin-top: 2px;
    border-right: 1.5px solid var(--muted-2);
    border-bottom: 1.5px solid var(--muted-2);
    transform: rotate(-45deg);
    opacity: 0.75;
    transition: transform 0.15s ease;
  }

  details[open] > summary::after {
    transform: rotate(45deg);
  }

  .list {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0;
  }

  .item {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.45rem 0.6rem;
    border-radius: 12px;
    color: var(--muted);
    transition: all 0.2s ease;
    font-size: 0.95rem;
    font-weight: 500;
    margin-bottom: 2px;
  }

  .item:hover {
    color: var(--fg);
    background: color-mix(in srgb, var(--panel-2), transparent 0%);
    text-decoration: none;
  }

  .active {
    background: color-mix(in srgb, var(--accent-dim), transparent 40%);
    color: color-mix(in srgb, var(--fg), transparent 0%);
  }

  .active::before {
    content: "";
    position: absolute;
    left: -1px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    border-radius: 2px;
    background: var(--accent);
  }

  .active:hover {
    background: color-mix(in srgb, var(--accent-dim), transparent 30%);
  }

  .active .sidebar-icon {
    stroke: var(--accent);
  }

  .icon {
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.8;
  }
</style>

<script>
  function initSidebar() {
    const sidebar = document.getElementById("sidebar");
    const overlay = document.getElementById("sidebarOverlay");
    const menuToggle = document.getElementById("sidebarToggle");
    const closeBtn = document.getElementById("sidebarClose");

    if (!sidebar || !overlay) return;

    const openSidebar = () => {
      sidebar.classList.add("open");
      overlay.classList.add("open");
      document.body.style.overflow = "hidden";
    };

    const closeSidebar = () => {
      sidebar.classList.remove("open");
      overlay.classList.remove("open");
      document.body.style.overflow = "";
    };

    menuToggle?.addEventListener("click", openSidebar);
    closeBtn?.addEventListener("click", closeSidebar);
    overlay.addEventListener("click", closeSidebar);

    const sidebarLinks = sidebar.querySelectorAll(".item");
    sidebarLinks.forEach((link) => {
      link.addEventListener("click", () => {
        if (window.innerWidth <= 1024) {
          closeSidebar();
        }
      });
    });

    const currentPath = window.location.pathname;
    const exactMatch = Array.from(sidebarLinks).find(
      (link) =>
        link.getAttribute("href") === currentPath ||
        link.getAttribute("href") === `${currentPath}/`,
    );

    sidebarLinks.forEach((link) => link.classList.remove("active"));

    if (exactMatch) {
      exactMatch.classList.add("active");
      exactMatch.scrollIntoView({ block: "nearest" });
    }

    const groups = Array.from(sidebar.querySelectorAll("details.group"));
    const activeGroup = exactMatch?.closest("details.group");
    groups.forEach((g) => {
      (g as HTMLDetailsElement).open = g === activeGroup;
    });

    if (!activeGroup && groups.length > 0) {
      (groups[0] as HTMLDetailsElement).open = true;
    }
  }

  document.addEventListener("astro:page-load", initSidebar);
  initSidebar();
</script>
