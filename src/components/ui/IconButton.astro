---
import type { HTMLAttributes } from "astro/types";

type IconButtonSize = "sm" | "md" | "lg" | "icon";

type Props = (HTMLAttributes<"button"> | HTMLAttributes<"a">) & {
  size?: IconButtonSize;
  as?: "button" | "a";
  href?: string;
  disabled?: boolean;
};

const {
  size = "md",
  as = "button",
  href,
  disabled = false,
  class: className,
  type = "button",
  ...rest
} = Astro.props as Props;

const isLink = as === "a" || typeof href === "string";
---

{
  isLink ? (
    <a
      href={href}
      class:list={[
        "ui-ibtn",
        `ui-ibtn--${size}`,
        disabled && "ui-ibtn--disabled",
        className,
      ]}
      aria-disabled={disabled ? "true" : undefined}
      tabindex={disabled ? -1 : undefined}
      {...rest}
    >
      <slot />
      <slot name="tooltip" />
    </a>
  ) : (
    <button
      type={type}
      disabled={disabled}
      class:list={[
        "ui-ibtn",
        `ui-ibtn--${size}`,
        disabled && "ui-ibtn--disabled",
        className,
      ]}
      {...rest}
    >
      <slot />
      <slot name="tooltip" />
    </button>
  )
}

<style>
  .ui-ibtn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    color: var(--muted);
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    transition:
      color 0.2s ease,
      background-color 0.2s ease;
    text-decoration: none;
  }

  .ui-ibtn:hover {
    color: var(--fg);
    background-color: var(--panel);
  }

  .ui-ibtn:focus-visible {
    outline: none;
    box-shadow: var(--ring);
  }

  .ui-ibtn:disabled,
  .ui-ibtn--disabled {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
  }

  .ui-ibtn--sm {
    width: 2rem;
    height: 2rem;
  }

  .ui-ibtn--md {
    width: 2.25rem;
    height: 2.25rem;
  }

  .ui-ibtn--lg {
    width: 2.75rem;
    height: 2.75rem;
  }

  .ui-ibtn--icon {
    width: 2.5rem;
    height: 2.5rem;
  }

  @media (max-width: 1024px) {
    .ui-ibtn--md {
      width: 2.75rem;
      height: 2.75rem;
      border-radius: 0.625rem;
    }
  }
</style>
