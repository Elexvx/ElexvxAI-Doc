---
import { Copy, Check } from '@lucide/astro';
---

<button class="copy-page-btn" type="button" id="copyPageFab" aria-live="polite">
  <span class="icon-idle"><Copy size={16} stroke-width={1.5} /></span>
  <span class="icon-success"><Check size={16} stroke-width={1.5} /></span>
  <span class="text">Copy Page</span>
</button>

<script>
  async function copyText(text: string) {
    if (navigator.clipboard?.writeText) {
      await navigator.clipboard.writeText(text);
      return;
    }
    const ta = document.createElement("textarea");
    ta.value = text;
    ta.style.position = "fixed";
    ta.style.opacity = "0";
    document.body.appendChild(ta);
    ta.focus();
    ta.select();
    document.execCommand("copy");
    ta.remove();
  }

  document.addEventListener("astro:page-load", () => {
    const btn = document.getElementById("copyPageFab");
    if (!(btn instanceof HTMLButtonElement)) return;
    if (btn.hasAttribute("data-copy-listener")) return;
    btn.setAttribute("data-copy-listener", "true");

    btn.addEventListener("click", async () => {
      const url = window.location.href;
      const textSpan = btn.querySelector(".text");
      try {
        await copyText(url);
        if (textSpan) textSpan.textContent = "Copied";
        btn.setAttribute("data-state", "copied");
        window.setTimeout(() => {
          if (textSpan) textSpan.textContent = "Copy Page";
          btn.removeAttribute("data-state");
        }, 1000);
      } catch {
        if (textSpan) textSpan.textContent = "Failed";
        btn.setAttribute("data-state", "error");
        window.setTimeout(() => {
          if (textSpan) textSpan.textContent = "Copy Page";
          btn.removeAttribute("data-state");
        }, 1000);
      }
    });
  });
</script>

<style>
  .copy-page-btn {
    position: fixed;
    right: 16px;
    bottom: 16px;
    z-index: 30;
    height: 36px;
    padding: 0 12px;
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--panel), transparent 5%);
    color: var(--fg);
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    box-shadow: var(--shadow-md);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    gap: 8px;
    transition: all 0.2s ease;
  }

  .icon-success {
    display: none;
  }

  .copy-page-btn[data-state="copied"] .icon-idle {
    display: none;
  }

  .copy-page-btn[data-state="copied"] .icon-success {
    display: flex;
    color: var(--accent);
  }

  .copy-page-btn:hover {
    border-color: var(--accent);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  .copy-page-btn[data-state="copied"] {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent-dim), var(--panel) 80%);
  }

  .copy-page-btn[data-state="error"] {
    border-color: var(--danger);
  }
  @media (max-width: 900px) {
    .copy-page-btn {
      right: 12px;
      bottom: 12px;
    }
  }
</style>
