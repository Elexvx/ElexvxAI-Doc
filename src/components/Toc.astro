---
import { Github, MessageSquare, X } from "@lucide/astro";

type Heading = { depth: number; slug: string; text: string };

type Props = {
  headings: Heading[];
  title: string;
};

const { headings, title } = Astro.props;
const items = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

<div class="mobileOverlay" id="tocOverlay"></div>
<aside class="toc" id="tocSidebar">
  <div class="tocMobileHeader">
    <span class="mobileTitle">{title}</span>
    <button class="closeBtn" id="tocClose" aria-label="Close table of contents">
      <X size={20} stroke-width={1.5} />
    </button>
  </div>
  <div class="tocTitle">{title}</div>
  <ul class="tocList" id="toc-list">
    {
      items.map((h) => (
        <li class:list={["tocItem", h.depth === 3 && "d3"]}>
          <a href={`#${h.slug}`}>{h.text}</a>
        </li>
      ))
    }
  </ul>

  <div class="railLinks">
    <a
      class="railLink"
      href="https://github.com/elexvx/ElexvxAI-Doc"
      target="_blank"
      rel="noopener noreferrer"
    >
      <Github size={14} stroke-width={1.5} />
      GitHub
    </a>
    <a
      class="railLink"
      href="https://github.com/elexvx/ElexvxAI-Doc/discussions"
      target="_blank"
      rel="noopener noreferrer"
    >
      <MessageSquare size={14} stroke-width={1.5} />
      Community
    </a>
  </div>
</aside>

<script>
  function setupToc() {
    const headings = Array.from(
      document.querySelectorAll(
        ".article-content h2, .article-content h3, article h2, article h3",
      ),
    ) as HTMLElement[];
    const tocItems = Array.from(document.querySelectorAll(".tocItem"));

    let ticking = false;

    const updateToc = () => {
      if (headings.length === 0 || tocItems.length === 0) return;

      let current = headings[0];
      for (const h of headings) {
        if (window.scrollY >= h.offsetTop - 120) {
          current = h;
        }
      }

      tocItems.forEach((item) => {
        item.classList.remove("active");
        const href = item.querySelector("a")?.getAttribute("href");
        if (href === `#${current?.id}`) {
          item.classList.add("active");
        }
      });
      ticking = false;
    };

    const onScroll = () => {
      if (!ticking) {
        window.requestAnimationFrame(updateToc);
        ticking = true;
      }
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    updateToc();

    // Mobile Drawer Logic
    const tocSidebar = document.getElementById("tocSidebar");
    const overlay = document.getElementById("tocOverlay");
    const tocToggle = document.getElementById("tocToggle");
    const closeBtn = document.getElementById("tocClose");

    const openToc = () => {
      tocSidebar?.classList.add("open");
      overlay?.classList.add("open");
      document.body.style.overflow = "hidden";
    };

    const closeToc = () => {
      tocSidebar?.classList.remove("open");
      overlay?.classList.remove("open");
      document.body.style.overflow = "";
    };

    tocToggle?.addEventListener("click", openToc);
    closeBtn?.addEventListener("click", closeToc);
    overlay?.addEventListener("click", closeToc);

    const links = document.querySelectorAll(".tocItem a");
    links.forEach((link) => {
      link.addEventListener("click", () => {
        if (window.innerWidth <= 1024) closeToc();
      });
    });
  }

  document.addEventListener("astro:page-load", setupToc);
  setupToc();
</script>

<style>
  .mobileOverlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 140;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .mobileOverlay.open {
    opacity: 1;
  }

  .tocMobileHeader {
    display: none;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 0;
    margin-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-2);
  }

  .mobileTitle {
    font-weight: 600;
    font-size: 1rem;
    color: var(--fg);
  }

  .closeBtn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: none;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    border-radius: 0.5rem;
  }

  .closeBtn:hover {
    color: var(--fg);
    background: var(--panel-2);
  }

  .toc {
    position: sticky;
    top: var(--header-h);
    max-height: calc(100vh - var(--header-h) - 1rem); /* Fix cutoff bug */
    overflow-y: auto;
    padding: 1.5rem 1.5rem 2rem 1rem;
    display: flex;
    flex-direction: column;
  }

  .tocTitle {
    font-size: 0.75rem;
    font-weight: 600; /* slightly lighter than 650 for a cleaner look */
    color: var(--fg); /* Darker heading for product feel */
    padding: 0 0 1rem 0; /* Align with track */
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .tocList {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    position: relative;
  }

  /* Add continuous vertical track line */
  .tocList::before {
    content: "";
    position: absolute;
    top: 6px;
    bottom: 0;
    left: 0;
    width: 1px;
    background-color: var(--border-2); /* Light track line */
    z-index: 0;
  }

  .tocItem {
    position: relative;
    padding: 0.35rem 0 0.35rem 1.2rem;
    margin-bottom: 2px;
    z-index: 1; /* keep above track */
  }

  /* Dot on the track */
  .tocItem::before {
    content: "";
    position: absolute;
    left: -2px; /* Center on the 1px line */
    top: 50%;
    transform: translateY(-50%);
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background-color: transparent;
    transition: background-color 0.2s ease;
  }

  .tocItem.active::before {
    background-color: var(--accent); /* Highlight dot */
  }

  .tocItem.active {
    /* No border-left anymore, relying on dot and text color */
  }

  .tocItem.active a {
    color: var(--fg);
    font-weight: 600; /* Stronger active state */
  }

  .tocItem.d3 {
    padding-left: 1.75rem;
  }

  .tocItem a {
    color: var(--muted-2); /* Lighter default color */
    text-decoration: none;
    font-size: 0.85rem;
    line-height: 1.4;
    transition: color 0.2s ease;
    display: block;
  }

  .tocItem a:hover {
    color: var(--muted);
  }

  .railLinks {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 0.75rem 0 0;
    border-top: 1px solid var(--border-2); /* Divider above links */
  }

  .railLink {
    font-size: 0.85rem;
    color: var(--muted);
    padding: 0.25rem 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .railLink:hover {
    color: var(--fg);
  }

  @media (max-width: 1024px) {
    .mobileOverlay {
      display: block;
      pointer-events: none;
    }
    .mobileOverlay.open {
      pointer-events: auto;
    }
    .toc {
      position: fixed;
      top: 0;
      right: 0;
      height: 100vh;
      max-height: 100vh;
      width: 300px;
      max-width: 85vw;
      z-index: 150;
      transform: translateX(100%);
      transition: transform 0.25s ease;
      background: var(--bg);
      border-left: 1px solid var(--border-2);
      padding: 0 1rem 1.5rem;
    }
    .toc.open {
      transform: translateX(0);
    }
    .tocMobileHeader {
      display: flex;
    }
    .tocTitle {
      display: none;
    }
    .tocList {
      margin-top: 1rem;
    }
  }
</style>
