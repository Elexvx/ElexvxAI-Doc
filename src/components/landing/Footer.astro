---
import { FlaskConical } from "@lucide/astro";
import AntigravityTitle from "./AntigravityTitle.astro";
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="top-section">
      <div class="slogan-col">
        <h2 class="slogan">探索智能边界</h2>
      </div>

      <div class="links-wrapper">
        <ul class="link-list">
          <li><a href="#">发表论文</a></li>
          <li><a href="#">开源项目</a></li>
          <li><a href="#">开放数据</a></li>
          <li><a href="#">模型代码</a></li>
          <li><a href="#">研究成果</a></li>
        </ul>
        <ul class="link-list">
          <li><a href="#">技术文档</a></li>
          <li><a href="#">API 参考</a></li>
          <li><a href="#">开发者社区</a></li>
          <li><a href="#">官方博客</a></li>
        </ul>
      </div>
    </div>

    <div class="middle-section">
      <AntigravityTitle />
    </div>

    <div class="bottom-section">
      <div class="brand">
        <div class="logo">
          <FlaskConical size={20} stroke-width={2} />
          <span class="brand-name">ElexvxAI Lab</span>
        </div>
      </div>
      <div class="bottom-links">
        <a href="#">关于我们</a>
        <a href="#">加入我们</a>
        <a href="#">隐私政策</a>
        <a href="#">服务条款</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 6rem 4rem 2rem;
    background-color: var(--panel);
    color: var(--fg);
    border-top: 1px solid var(--border);
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
  }

  .top-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .slogan-col {
    display: flex;
  }

  .slogan {
    font-size: 2.5rem;
    font-weight: 500;
    margin: 0;
    line-height: 1.2;
    color: var(--fg);
  }

  .links-wrapper {
    display: grid;
    grid-template-columns: repeat(2, max-content);
    gap: 8rem;
  }

  .link-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .link-list a {
    color: var(--fg);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: opacity 0.2s;
  }

  .link-list a:hover {
    opacity: 0.7;
    color: var(--accent);
  }

  .middle-section {
    margin: 8rem 0 6rem;
    text-align: center;
    width: 100%;
    overflow: hidden;
  }

  @media (min-width: 1400px) {
  }

  .bottom-section {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    flex-wrap: wrap;
    gap: 2rem;
  }

  .brand .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--fg);
  }

  .brand-name {
    font-size: 1.125rem;
    font-weight: 600;
  }

  .bottom-links {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .bottom-links a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.2s;
  }

  .bottom-links a:hover {
    color: var(--accent);
  }

  @media (max-width: 1024px) {
    .links-wrapper {
      gap: 4rem;
    }
    .footer {
      padding: 4rem 2rem 2rem;
    }
    .slogan {
      font-size: 2rem;
    }
  }

  @media (max-width: 768px) {
    .top-section {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .links-wrapper {
      gap: 4rem;
    }
    .middle-section {
      margin-top: 5rem;
      margin-bottom: 4rem;
    }
    .huge-title {
      font-size: 14vw;
    }
    .bottom-section {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }
    .bottom-links {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
