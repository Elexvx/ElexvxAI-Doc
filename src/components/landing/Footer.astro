---
import { FlaskConical } from "@lucide/astro";
import AntigravityTitle from "./AntigravityTitle.astro";
import "../../styles/footer.css";

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-content">
    <div class="top-section">
      <div class="slogan-col">
        <h2 class="slogan">探索智能边界</h2>
      </div>

      <div class="links-wrapper">
        <ul class="link-list">
          <li><a href="#">发表论文</a></li>
          <li><a href="#">开源项目</a></li>
          <li><a href="#">开放数据</a></li>
          <li><a href="#">模型代码</a></li>
          <li><a href="#">研究成果</a></li>
        </ul>
        <ul class="link-list">
          <li><a href="#">技术文档</a></li>
          <li><a href="#">API 参考</a></li>
          <li><a href="#">开发者社区</a></li>
          <li><a href="#">官方博客</a></li>
        </ul>
      </div>
    </div>

    <div class="middle-section">
      <AntigravityTitle />
    </div>

    <div class="bottom-section">
      <div class="brand">
        <div class="logo">
          <FlaskConical size={20} stroke-width={2} />
          <span class="brand-name">ElexvxAI Lab</span>
        </div>
      </div>
      <div class="bottom-links">
        <a href="#">关于我们</a>
        <a href="#">加入我们</a>
        <a href="#">隐私政策</a>
        <a href="#">服务条款</a>
      </div>
    </div>
  </div>
</footer>
