---
const features = [
  {
    title: "核心研究",
    icon: "science",
    desc: "深度学习算法与基础模型，拓展生成式任务的 AI 能力边界。",
  },
  {
    title: "开源贡献",
    icon: "code",
    desc: "向全球研究社区贡献最前沿的代码、预训练模型和大规模数据集。",
  },
  {
    title: "工业应用",
    icon: "factory",
    desc: "部署可扩展的 AI 解决方案，优化制造、物流和供应链。",
  },
];
---

<section class="features-section">
  <div class="container">
    <div class="grid">
      {
        features.map((feature) => (
          <div class="card">
            <div class="card-content">
              <div class="icon-container">
                {feature.icon === "science" && (
                  <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M19.8 18.4L14 10.67V6.5l1.35-1.69c.26-.33.03-.81-.4-.81H9.05c-.43 0-.66.48-.4.81L10 6.5v4.17L4.2 18.4c-.49.66-.02 1.6.8 1.6h14c.82 0 1.29-.94.8-1.6z" />
                  </svg>
                )}
                {feature.icon === "code" && (
                  <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0l4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4z" />
                  </svg>
                )}
                {feature.icon === "factory" && (
                  <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M22 22H2V11l7-3v2h5v-2l5 3v-2l3 3z" />
                  </svg>
                )}
              </div>
              <h3 class="headline-small">{feature.title}</h3>
              <p class="body-medium">{feature.desc}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .features-section {
    padding: 6rem 1.5rem;
    background-color: var(--md-sys-color-surface);
    color: var(--md-sys-color-on-surface);
    display: flex;
    justify-content: center;
  }

  .container {
    max-width: 1200px;
    width: 100%;
    display: flex;
    flex-direction: column;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  .card {
    background-color: var(--md-sys-color-surface-container-low);
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--md-sys-color-outline-variant);
    display: flex;
    flex-direction: column;
  }

  .card-content {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    flex: 1;
  }

  .icon-container {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--md-sys-color-primary);
  }

  .icon-container svg {
    width: 24px;
    height: 24px;
  }

  .headline-small {
    font-size: 1.25rem;
    font-weight: 500;
    margin: 0;
    color: var(--md-sys-color-on-surface);
  }

  .body-medium {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--md-sys-color-on-surface-variant);
    margin: 0;
    flex: 1;
  }
</style>
