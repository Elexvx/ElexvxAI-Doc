---
import type { CollectionEntry } from "astro:content";
import { getLucideIcon } from "../../lib/lucide-icons";

type FeatureItem = CollectionEntry<"landing">["data"]["features"][number];

interface Props {
  data: FeatureItem[];
}

const { data: features } = Astro.props;
---

<section class="features-section">
  <div class="container">
    <div class="grid">
      {
        features.map((feature, index) => {
          const Icon = getLucideIcon(feature.icon);
          return (
            <a href={feature.href} class="card group">
              <div class={`card-hover-bg preset-${index + 1}`} />
              <div class="card-content">
                <div class="icon-container">
                  <Icon size={24} stroke-width={1.5} />
                </div>
                <div class="text-wrapper">
                  <h3 class="headline-small">{feature.title}</h3>
                  <p class="body-medium">{feature.desc}</p>
                </div>
              </div>
            </a>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .features-section {
    padding: 1rem 0 3rem;
    background-color: var(--bg);
    color: var(--fg);
    display: flex;
    justify-content: center;
    content-visibility: auto;
    contain-intrinsic-size: 720px;
  }

  .container {
    display: flex;
    flex-direction: column;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 767px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  /* 1:1 OpenAI Primary Card Style */
  .card {
    position: relative;
    background-color: #f9f9f9;
    border-radius: 8px; /* OpenAI uses 8px */
    border: none;
    overflow: hidden;
    text-decoration: none;
    min-height: 220px;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s ease;
    -webkit-tap-highlight-color: transparent;
  }

  .card:hover {
    text-decoration: none;
  }

  /* The hidden gradient background that fades in on hover */
  :global([data-theme="dark"]) .card {
    background-color: rgba(255, 255, 255, 0.05);
  }

  .card-hover-bg {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition:
      opacity 0.45s ease,
      filter 0.25s ease;
    z-index: 1;
  }

  /* Subtle grain for a softer, official-like hover finish */
  .card-hover-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.26) 0.5px, transparent 0.5px);
    background-size: 2.6px 2.6px;
    opacity: 0.06;
    pointer-events: none;
  }

  /* Hover gradients tuned to match the provided OpenAI reference captures */
  .preset-1 {
    background-image:
      radial-gradient(95% 120% at 50% 48%, rgba(228, 241, 252, 0.9) 0%, rgba(209, 231, 248, 0.55) 34%, rgba(209, 231, 248, 0) 68%),
      radial-gradient(85% 95% at 70% 2%, rgba(36, 115, 236, 0.88) 0%, rgba(41, 156, 255, 0.62) 38%, rgba(41, 156, 255, 0) 72%),
      radial-gradient(78% 94% at 98% 86%, rgba(57, 178, 247, 0.72) 0%, rgba(57, 178, 247, 0) 66%),
      linear-gradient(140deg, #90cee9 0%, #67addd 46%, #428eca 100%);
  }

  .preset-2 {
    background-image:
      radial-gradient(42% 54% at 45% 31%, rgba(141, 176, 44, 0.6) 0%, rgba(141, 176, 44, 0.32) 42%, rgba(141, 176, 44, 0) 78%),
      radial-gradient(46% 52% at 38% 23%, rgba(230, 190, 102, 0.52) 0%, rgba(230, 190, 102, 0.24) 40%, rgba(230, 190, 102, 0) 76%),
      radial-gradient(64% 80% at 10% 92%, rgba(66, 178, 205, 0.42) 0%, rgba(66, 178, 205, 0) 66%),
      radial-gradient(70% 94% at 0% 40%, rgba(167, 114, 228, 0.36) 0%, rgba(167, 114, 228, 0) 72%),
      linear-gradient(145deg, #b7addf 0%, #a999de 46%, #89afe5 100%);
  }

  .preset-3 {
    background-image:
      radial-gradient(82% 95% at 12% 76%, rgba(146, 229, 174, 0.74) 0%, rgba(146, 229, 174, 0) 63%),
      radial-gradient(95% 108% at 86% 14%, rgba(105, 180, 236, 0.74) 0%, rgba(105, 180, 236, 0) 63%),
      radial-gradient(72% 78% at 52% 55%, rgba(100, 199, 191, 0.45) 0%, rgba(100, 199, 191, 0) 71%),
      linear-gradient(145deg, #8cd1b8 0%, #67b5c9 48%, #5e9bd7 100%);
  }

  .card-content {
    position: relative;
    z-index: 2; /* above the hover bg */
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: 100%;
  }

  .icon-container {
    color: var(--fg);
    transition: color 0.7s ease;
  }

  /* Push text to the bottom to match OpenAI layout */
  .text-wrapper {
    margin-top: auto;
  }

  .headline-small {
    font-size: 1.125rem; /* 18px */
    font-weight: 600; /* slightly bolder, looks precise */
    margin: 0 0 0.5rem 0; /* slight gap to description */
    color: var(--fg);
    transition: color 0.7s ease;
  }

  .body-medium {
    font-size: 0.9375rem; /* 15px */
    line-height: 1.6;
    color: var(--muted);
    margin: 0;
    transition: color 0.7s ease;
  }

  :global([data-theme="dark"]) .body-medium {
    color: rgba(
      255,
      255,
      255,
      0.7
    ); /* ensure legibility in dark mode before hover */
  }

  @media (hover: hover), (max-width: 768px) {
    .card:hover {
      transform: none;
      box-shadow: none;
    }

    :global([data-theme="light"]) .card:hover {
      box-shadow: none;
    }

    .card:hover .card-hover-bg {
      opacity: 1;
      filter: saturate(1.04) contrast(1.02);
    }

    .card:hover .icon-container {
      color: #ffffff;
    }

    .card:hover .headline-small {
      color: #ffffff;
    }

    .card:hover .body-medium {
      color: rgba(255, 255, 255, 0.9);
    }
  }

  @media (max-width: 768px) {
    .features-section {
      padding: 1.25rem 0 2.5rem;
    }

    .grid {
      gap: 1rem;
    }

    .card {
      min-height: unset;
    }

    .card-content {
      padding: 1.25rem;
      gap: 0.75rem;
    }

    .icon-container :global(svg) {
      width: 22px;
      height: 22px;
    }

    .headline-small {
      margin-bottom: 0.35rem;
    }

    .body-medium {
      line-height: 1.5;
    }
  }

  @media (max-width: 480px) {
    .features-section {
      padding: 1rem 0 2rem;
    }

    .grid {
      gap: 0.875rem;
    }

    .card-content {
      padding: 1rem;
    }
  }
</style>
