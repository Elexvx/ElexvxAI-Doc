---
import { getDocUrl } from "../../lib/docs";
import { SITE } from "../../config/site";

const zh = getDocUrl({ lang: "zh", version: SITE.defaultVersion });
---

<section class="hero-section">
  <div class="container">
    <div class="content">
      <div class="tag">
        <span class="dot"></span>
        AI 创新实验室
      </div>
      <h1 class="headline">
        推动智能技术
        <span class="highlight">赋能工业创新</span>
      </h1>
      <p class="subhead">
        跨越 AI 理论研究与实际工业应用之间的鸿沟，构建下一代智能系统。
      </p>

      <div class="actions">
        <a href={zh} class="btn-filled">
          我们的项目
        </a>
        <a href={zh} class="btn-outlined">
          查看文档
        </a>
      </div>
    </div>


  </div>
</section>

<style>
  .hero-section {
    padding: 4rem 1.5rem;
    background-color: var(--md-sys-color-surface);
    color: var(--md-sys-color-on-surface);
    display: flex;
    justify-content: center;
  }

  .container {
    max-width: 900px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 2.5rem;
  }

  @media (max-width: 900px) {
    .container {
      gap: 2rem;
    }
  }

  /* Content */
  .content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.25rem 0.75rem;
    background-color: var(--md-sys-color-secondary-container);
    color: var(--md-sys-color-on-secondary-container);
    border-radius: 100px;
    font-size: 0.875rem;
    font-weight: 500;
    width: fit-content;
  }

  .dot {
    width: 6px;
    height: 6px;
    background-color: currentColor;
    border-radius: 50%;
  }

  .headline {
    font-family: var(--md-sys-typescale-display-font);
    font-size: 3.5rem;
    line-height: 1.1;
    font-weight: 600;
    margin: 0;
    color: var(--md-sys-color-on-surface);
  }

  .highlight {
    color: var(--md-sys-color-primary);
    display: block;
    font-weight: 700;
  }

  .subhead {
    font-family: var(--md-sys-typescale-body-font);
    font-size: 1.125rem;
    line-height: 1.5;
    color: var(--md-sys-color-on-surface-variant);
    max-width: 600px;
  }

  .actions {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn-filled {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background-color: var(--md-sys-color-primary);
    color: var(--md-sys-color-on-primary);
    border-radius: 100px;
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .btn-filled:hover {
    background-color: var(--md-sys-color-secondary);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.2);
    text-decoration: none;
  }

  .btn-outlined {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background-color: transparent;
    border: 1px solid var(--md-sys-color-outline);
    color: var(--md-sys-color-on-surface);
    border-radius: 100px;
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .btn-outlined:hover {
    background-color: var(--md-sys-color-surface-variant);
    border-color: var(--md-sys-color-outline-variant);
    text-decoration: none;
  }
</style>
