---
import { ChevronDown, ListTree } from "@lucide/astro";
type Heading = { depth: number; slug: string; text: string };

type Props = {
    headings: Heading[];
    title: string;
};

const { headings, title } = Astro.props;

// Filter headings as we only care about h2 and h3
const items = headings.filter((h) => h.depth >= 2 && h.depth <= 3);

// If no elements, do not render anything
if (items.length === 0) return null;
---

<div class="mobile-toc-container">
    <details class="mobile-toc">
        <summary class="mobile-toc-summary">
            <div class="summary-content">
                <ListTree size={16} stroke-width={1.5} />
                <span class="summary-title">{title}</span>
            </div>
            <ChevronDown class="chevron" size={16} stroke-width={1.5} />
        </summary>
        <div class="mobile-toc-body">
            <ul class="mobile-toc-list">
                {
                    items.map((h) => (
                        <li
                            class:list={[
                                "mobile-toc-item",
                                h.depth === 3 && "d3",
                            ]}
                        >
                            <a href={`#${h.slug}`}>{h.text}</a>
                        </li>
                    ))
                }
            </ul>
        </div>
    </details>
</div>

<style>
    .mobile-toc-container {
        display: none;
        margin-bottom: 2rem;
    }

    /* Only display the mobile TOC on screens smaller than 1100px */
    @media (max-width: 1100px) {
        .mobile-toc-container {
            display: block;
        }
    }

    .mobile-toc {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        overflow: hidden;
    }

    .mobile-toc-summary {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.85rem 1rem;
        cursor: pointer;
        list-style: none; /* Hide default triangle */
        background: var(--panel-2);
        user-select: none;
        transition: background 0.2s ease;
    }

    .mobile-toc-summary::-webkit-details-marker {
        display: none;
    }

    .mobile-toc-summary:hover {
        background: color-mix(in srgb, var(--panel-2), transparent 20%);
    }

    .summary-content {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--fg);
        font-weight: 550;
        font-size: 0.95rem;
    }

    .chevron {
        color: var(--muted);
        transition: transform 0.2s ease;
    }

    .mobile-toc[open] .chevron {
        transform: rotate(180deg);
    }

    .mobile-toc-body {
        border-top: 1px solid var(--border);
        padding: 1rem;
        background: var(--bg);
    }

    .mobile-toc-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .mobile-toc-item {
        font-size: 0.9rem;
    }

    .mobile-toc-item a {
        color: var(--muted);
        text-decoration: none;
        transition: color 0.15s;
        display: block;
    }

    .mobile-toc-item a:hover {
        color: var(--fg);
    }

    .mobile-toc-item.d3 {
        padding-left: 1.25rem;
        font-size: 0.85rem;
        opacity: 0.85;
    }

    /* When JS handles smooth scroll and marks the active link */
    .mobile-toc-item.active a {
        color: var(--accent);
        font-weight: 500;
    }
</style>

<script>
    // Very simplistic script to handle closing the details upon clicking a link
    // Optional active state highlighting could be added here
    function setupMobileToc() {
        const details = document.querySelector(".mobile-toc");
        if (!details) return;

        const links = details.querySelectorAll(".mobile-toc-item a");
        links.forEach((link) => {
            link.addEventListener("click", () => {
                (details as HTMLDetailsElement).open = false;
            });
        });
    }

    document.addEventListener("astro:page-load", setupMobileToc);
    setupMobileToc();
</script>
