---
import { LifeBuoy, Users, Sparkles, Rss } from "@lucide/astro";
---

<div class="help-section">
  <div class="help-container container">
    <a href="#" class="help-card">
      <div class="icon-wrapper">
        <LifeBuoy size={24} stroke-width={1.5} />
      </div>
      <h3>帮助中心</h3>
      <p>常见问题与使用指南</p>
    </a>

    <a href="#" class="help-card">
      <div class="icon-wrapper">
        <Users size={24} stroke-width={1.5} />
      </div>
      <h3>开发者社区</h3>
      <p>与开发者交流实践经验</p>
    </a>

    <a href="#" class="help-card">
      <div class="icon-wrapper">
        <Sparkles size={24} stroke-width={1.5} />
      </div>
      <h3>项目合作</h3>
      <p>了解联合研发与合作方案</p>
    </a>

    <a href="#" class="help-card">
      <div class="icon-wrapper">
        <Rss size={24} stroke-width={1.5} />
      </div>
      <h3>系统状态</h3>
      <p>查看服务运行状态与公告</p>
    </a>
  </div>
</div>

<style>
  .help-section {
    padding: 3rem 1.5rem;
    background-color: var(--bg);
    border-top: 1px solid var(--border);
  }

  .help-container {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .help-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    color: inherit;
    gap: 0.35rem;
  }

  .icon-wrapper {
    margin-bottom: 0.4rem;
    color: var(--fg);
  }

  h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    color: var(--fg);
  }

  p {
    font-size: 0.875rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.5;
  }

  @media (max-width: 900px) {
    .help-section {
      padding: 2.75rem 1rem;
    }

    .help-container {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }

  @media (max-width: 600px) {
    .help-section {
      padding: 2.5rem 1rem;
    }

    .help-container {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }
</style>
