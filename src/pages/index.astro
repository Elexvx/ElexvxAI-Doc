---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import { SITE } from '../config/site';
import Hero from '../components/landing/Hero.astro';
import LatestNews from '../components/landing/LatestNews.astro';
import Features from '../components/landing/Features.astro';
import Footer from '../components/landing/Footer.astro';
---

<BaseLayout lang="zh" title={SITE.title} description="推动智能技术 赋能工业创新">
  <Header lang="zh" version={SITE.defaultVersion} />
  <main class="landing-page">
    <Hero />
    <Features />
    <LatestNews lang="zh" />
    <Footer />
  </main>
</BaseLayout>


<style is:global>
  /* Override BaseLayout defaults for landing page */
  body {
    background-color: var(--bg);
    color: var(--fg);
  }
  
  /* Ensure header blends in or stands out */
  .hdr {
    background: var(--bg) !important;
    border-bottom: 1px solid var(--border) !important;
  }

  @media (max-width: 768px) {
    .landing-page .container {
      width: 100%;
      margin-inline: 0;
    }
  }

</style>
