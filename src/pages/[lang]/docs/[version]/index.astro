---
import { getCollection } from "astro:content";
import { parseDocId } from "../../../../lib/docs";
import RedirectPage from "../../../../components/RedirectPage.astro";

export async function getStaticPaths() {
  const entries = await getCollection("docs");
  const indexEntries = entries.filter((e) => {
    const p = parseDocId(e.id);
    return p.slug === "" || p.slug === "index";
  });

  return indexEntries.map((entry) => {
    const p = parseDocId(entry.id);
    return {
      params: { lang: p.lang, version: p.version },
    };
  });
}
const { lang, version } = Astro.params;
const target = `/${lang}/${version}/`;
---
<RedirectPage target={target} lang={lang} />
