---
import { getCollection } from "astro:content";
import { parseDocId } from "../../../../lib/docs";
import RedirectPage from "../../../../components/RedirectPage.astro";

export async function getStaticPaths() {
  const entries = await getCollection("docs");
  const pages = entries.filter((e) => !e.id.endsWith("/index"));

  return pages.flatMap((entry) => {
    const p = parseDocId(entry.id);
    const slug = p.rest.join("/");
    if (!slug) return [];
    return [
      {
        params: { lang: p.lang, version: p.version, slug },
      },
    ];
  });
}
const { lang, version } = Astro.params;
const slug = Astro.params.slug ?? "";
const target = `/${lang}/${version}/${slug}/`;
---
<RedirectPage target={target} lang={lang} />
